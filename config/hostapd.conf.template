# hostapd configuration template
# Used by start-hotspot.sh

interface=wlan0
driver=nl80211

# WiFi configuration
ssid=MagicMirror-Setup
hw_mode=g
channel=7
wmm_enabled=0

# Access control
macaddr_acl=0
auth_algs=1
ignore_broadcast_ssid=0

# WPA2 encryption
wpa=2
wpa_passphrase=magicmirror
wpa_key_mgmt=WPA-PSK
wpa_pairwise=TKIP
rsn_pairwise=CCMP
